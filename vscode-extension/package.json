{
  "name": "jules-vscode",
  "displayName": "Jules Studio",
  "description": "Manage Google Jules AI coding sessions directly from VS Code — session sidebar, plan approval, inline diffs, CodeLens actions, and proactive notifications.",
  "version": "0.2.0-beta.4",
  "preview": true,
  "publisher": "tazztone",
  "icon": "media/jules-icon-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tazztone/jules-studio"
  },
  "homepage": "https://github.com/tazztone/jules-studio",
  "bugs": {
    "url": "https://github.com/tazztone/jules-studio/issues"
  },
  "license": "MIT",
  "keywords": [
    "jules",
    "AI",
    "coding agent",
    "google",
    "automation",
    "deepmind"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jules",
          "title": "Jules Studio",
          "icon": "media/jules-icon.svg"
        }
      ]
    },
    "views": {
      "jules": [
        {
          "id": "julesSessions",
          "name": "Sessions",
          "type": "tree",
          "icon": "media/jules-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "jules.setupWizard",
        "title": "Jules: Setup Wizard",
        "category": "Jules",
        "icon": "$(gear)"
      },
      {
        "command": "jules.setApiKey",
        "title": "Jules: Set API Key",
        "category": "Jules"
      },
      {
        "command": "jules.createSession",
        "title": "Jules: Create New Session",
        "category": "Jules"
      },
      {
        "command": "jules.refreshSessions",
        "title": "Jules: Refresh Sessions",
        "category": "Jules",
        "icon": "$(refresh)"
      },
      {
        "command": "jules.openSession",
        "title": "Jules: Open Session Detail",
        "category": "Jules"
      },
      {
        "command": "jules.approvePlan",
        "title": "Jules: Approve Plan",
        "category": "Jules",
        "icon": "$(check)"
      },
      {
        "command": "jules.applyPatch",
        "title": "Pull & Apply Changes to Local Files",
        "category": "Jules",
        "icon": "$(cloud-download)"
      },
      {
        "command": "jules.deleteSession",
        "title": "Jules: Delete Session",
        "category": "Jules",
        "icon": "$(trash)"
      },
      {
        "command": "jules.openInBrowser",
        "title": "Jules: Open in Browser",
        "category": "Jules",
        "icon": "$(globe)"
      },
      {
        "command": "jules.createSessionWithSelection",
        "title": "Jules: New Session with Selection",
        "category": "Jules"
      },
      {
        "command": "jules.sendTerminalToJules",
        "title": "Jules: Send Terminal Error to Jules",
        "category": "Jules",
        "icon": "$(terminal)"
      },
      {
        "command": "jules.codeLensAction",
        "title": "Jules: CodeLens Action",
        "category": "Jules"
      }
    ],
    "viewsWelcome": [
      {
        "view": "julesSessions",
        "contents": "Welcome to Jules Studio! 🐙\nTo get started, you need to configure your API key.\n[Get API Key from Jules Settings](https://jules.google.com/settings)\n[Configure API Key](command:jules.setupWizard)",
        "when": "!jules:hasApiKey"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "jules.createSessionWithSelection",
          "group": "navigation",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "jules.refreshSessions",
          "when": "view == julesSessions",
          "group": "navigation"
        },
        {
          "command": "jules.createSession",
          "when": "view == julesSessions",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "jules.approvePlan",
          "when": "view == julesSessions && viewItem == state-awaiting-plan-approval",
          "group": "inline"
        },
        {
          "command": "jules.applyPatch",
          "when": "view == julesSessions && viewItem == state-completed",
          "group": "inline"
        },
        {
          "command": "jules.deleteSession",
          "when": "view == julesSessions",
          "group": "1_modification"
        },
        {
          "command": "jules.openInBrowser",
          "when": "view == julesSessions",
          "group": "navigation"
        }
      ],
      "terminal/context": [
        {
          "command": "jules.sendTerminalToJules",
          "group": "navigation",
          "when": "jules:hasApiKey"
        }
      ]
    },
    "configuration": {
      "title": "Jules Studio",
      "properties": {
        "jules.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Jules CodeLens actions above functions and classes."
        },
        "jules.autoRefreshInterval": {
          "type": "number",
          "default": 60,
          "minimum": 0,
          "description": "Auto-refresh interval in seconds (0 to disable). Enables proactive notifications."
        },
        "jules.autoApplyAfterApproval": {
          "type": "boolean",
          "default": false,
          "description": "Automatically pull and apply changes when a session completes."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext .ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "glob": "^10.3.10",
    "typescript": "^5.3.3",
    "@vscode/test-electron": "^2.3.8"
  }
}
